# Required — Actual Budget connection
ACTUAL_SERVER_URL=https://budget.example.com
ACTUAL_SERVER_PASSWORD=your-password-here
ACTUAL_SYNC_ID=your-sync-id-here

# Required — Monthly spending target in dollars
FAFO_MONTHLY_TARGET=5000

# Optional — Reconciliation window
FAFO_RECON_START_DAY=28    # Day of month to start reconciliation
FAFO_RECON_END_DAY=5       # Day of next month to stop reconciliation
FAFO_RECON_TIME=02:00      # Time of day to run (HH:MM, 24hr)
TZ=America/New_York        # Timezone

# Optional — Category configuration
# FAFO_OTHER_CATEGORY=Everything Else   # Name of catch-all category in Other group

# Optional — Bank sync
# FAFO_BANK_SYNC=true      # Sync linked bank accounts before reconciliation

# Optional — Safety
# FAFO_DRY_RUN=true        # Log changes without applying them

# Optional — PCE inflation adjustment
# When FRED_API_KEY is set, FAFO_MONTHLY_TARGET is automatically adjusted for
# cumulative PCE inflation since BUDGET_START_DATE. Allowances are only
# inflation-adjusted if BASE_ALLOWANCE_* vars are provided.
# FRED_API_KEY=your-fred-api-key
# BUDGET_START_DATE=2025-05-01        # Month the budget baseline was set (YYYY-MM-DD)
# BASE_ALLOWANCE_ALICE=200            # Optional: base allowance per household member
# BASE_ALLOWANCE_BOB=200

# Optional — PayPal Debit Card email import
# Polls an IMAP inbox for PayPal receipts and imports them into Actual.
# Use a dedicated inbox that only receives forwarded PayPal receipts (IMAP creds
# grant full-mailbox access). Create an Actual account matching PAYPAL_ACTUAL_ACCOUNT.
# PAYPAL_IMPORT_ENABLED=true
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=paypal-receipts@example.com
# IMAP_PASSWORD=your-app-password
# IMAP_MAILBOX=INBOX
# PAYPAL_FROM=paypal.com               # Substring the sender must contain
# PAYPAL_ACTUAL_ACCOUNT=M Paypal       # Exact Actual account name
# PAYPAL_POLL_CRON=*/10 * * * *        # Poll every 10 minutes
